<Window x:Class="SimpleWindowsInstallerCleaner.ShortcutOfferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create shortcut"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static SystemCommands.CloseWindowCommand}"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnNoThanks"/>
    </Window.CommandBindings>

    <Border Background="#0f172a" CornerRadius="16" Padding="32,28"
            MaxWidth="420" MinWidth="340"
            BorderBrush="#334155" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Add to Start Menu?" Foreground="#f8fafc" FontSize="16"
                       FontWeight="SemiBold" Margin="0,0,0,10"/>

            <TextBlock Text="Add InstallerClean to your Start Menu so you can find it later via Windows Search."
                       Foreground="#94a3b8" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <CheckBox x:Name="DesktopCheckBox" Content="Also add a desktop shortcut"
                      Foreground="#cbd5e1" FontSize="12"
                      Margin="0,0,0,20" IsChecked="False"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostPill}" Content="No thanks"
                        Click="OnNoThanks" Margin="0,0,8,0"
                        Height="36" Padding="20,0" FontSize="13"/>
                <Button Style="{StaticResource AccentPill}" Content="Add shortcut"
                        Click="OnAddShortcut"
                        Height="36" Padding="20,0" FontSize="13"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
